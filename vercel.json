{
  "functions": {
    "api/events/**/*.js": {
      "maxDuration": 30
    },
    "api/web-push-subscribe.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.js"
    },
    {
      "source": "/lugar/:locality/",
      "destination": "/api/[locality].js"
    },
    {
      "source": "/eventos-(de-)?:when(hoy|esta-semana|este-mes)/",
      "destination": "/api/events/by-time/[when].js"
    },
    {
      "source": "/:slug([a-zA-Z0-9-]+-[a-zA-Z0-9-]+-.+-.+-.+-?.*h?)",
      "destination": "/api/events/by-slug/[slug].js"
    },
    {
      "source": "/:slug([a-z0-9-]+-[a-f0-9]{8})",
      "destination": "/api/events/by-slug/[slug].js"
    }
  ],
  "redirects": [
    {
      "source": "/lugar/traslasierra/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/lugar/villa-de-merlo/",
      "destination": "/lugar/merlo/",
      "permanent": true
    },
    {
      "source": "/lugar/san-javier/",
      "destination": "/lugar/san-javier-y-yacanto/",
      "permanent": true
    },
    {
      "source": "/lugar/yacanto/",
      "destination": "/lugar/san-javier-y-yacanto/",
      "permanent": true
    },
    {
      "source": "/:query(.+%20.*)",
      "destination": "/?q=:query",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=7200"
        }
      ]
    },
    {
      "source": "/lugar/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=1800, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/eventos-(de-)?(hoy|esta-semana|este-mes)/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=900"
        }
      ]
    },
    {
      "source": "/:slug([a-z0-9-]+-[a-f0-9]{8})",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}